# Exemplo para rodar o BifrostAuth via "docker compose" SEM clonar o repositório.
# 1) Baixe este arquivo + o docker-compose.pull.yml
# 2) Copie para .env.bifrostauth.pull e ajuste os valores
# 3) Rode: docker compose --env-file .env.bifrostauth.pull -f docker-compose.pull.yml up -d

# Imagem publicada
BIFROSTAUTH_IMAGE=ghcr.io/SEU_ORG/SEU_REPO:latest

# Postgres (local)
POSTGRES_DB=authsti
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234

# API
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Server=postgres;Port=5432;Database=authsti;Username=postgres;Password=1234

# JWT
Jwt__Key=CHANGE_ME_STRONG_JWT_KEY
Jwt__Issuer=BifrostAuth

# Migrations
Migrations__RunOnStartup=true

# Seeds (cria admin + application default)
Seed__Admin__Enabled=true
Seed__Admin__Password=Admin@123

Seed__Application__Enabled=true
Seed__Application__ClientSecret=dev-client-secret-change-me

# Redirect permitido para o client_id default (bifrost_app_8080)
# Ajuste para o host do seu frontend (origem) usado no /callback.
Seed__Application__RedirectUrl=http://localhost:5173
