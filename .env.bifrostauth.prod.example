# Exemplo de env para rodar "como produção".
# Copie este arquivo para `.env.bifrostauth.prod` e substitua os valores.

# Postgres (usado no docker-compose.prod.yml)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API (ASP.NET Core)
ASPNETCORE_ENVIRONMENT=Production

# Connection string (precisa bater com o POSTGRES_PASSWORD acima)
ConnectionStrings__DefaultConnection=Server=postgres;Port=5432;Database=authsti;Username=postgres;Password=CHANGE_ME_STRONG_PASSWORD

# JWT (use uma chave forte e mantenha fora do git)
Jwt__Key=CHANGE_ME_STRONG_JWT_KEY
Jwt__Issuer=BifrostAuth
Jwt__Audience=BifrostAuth

# FluentMigrator
# Em produção, você pode decidir entre:
# - true: a própria API aplica migrations no startup
# - false: você aplica migrations em pipeline/job antes de subir a API
Migrations__RunOnStartup=true

# NHibernate
NHibernate__SchemaUpdateEnabled=false
NHibernate__ShowSql=false
NHibernate__FormatSql=false
NHibernate__AdoNetBatchSize=20

# Seeds (por padrão, DESLIGADO em produção)
Seed__Admin__Enabled=false
Seed__Application__Enabled=false

# Se for habilitar seeds em produção (não recomendado automático sem necessidade):
# Seed__Admin__Enabled=true
# Seed__Admin__Login=admin
# Seed__Admin__Email=admin@bifrost.local
# Seed__Admin__Password=CHANGE_ME_STRONG_ADMIN_PASSWORD
#
# Seed__Application__Enabled=true
# Seed__Application__Name=BifrostAuth
# Seed__Application__ClientId=bifrost_app_8080
# Seed__Application__ClientSecret=CHANGE_ME_STRONG_APP_SECRET
# Seed__Application__RedirectUrl=
